{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SecurityReport",
  "type": "object",
  "properties": {
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "severity": {
            "type": "string",
            "enum": [
              "CRITICAL",
              "HIGH",
              "MEDIUM",
              "LOW"
            ]
          },
          "vulnerability_type": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "remediation_code": {
            "type": "string"
          }
        },
        "required": [
          "id",
          "severity",
          "vulnerability_type",
          "description",
          "remediation_code"
        ]
      }
    }
  },
  "required": [
    "findings"
  ]
}
