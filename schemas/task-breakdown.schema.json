{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "TaskBreakdown",
  "type": "object",
  "properties": {
    "tasks": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "dependencies": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "required": [
          "id",
          "title",
          "description",
          "dependencies"
        ]
      }
    }
  },
  "required": [
    "tasks"
  ]
}
